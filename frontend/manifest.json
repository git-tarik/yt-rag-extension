{
  "manifest_version": 3,
  "name": "YouTube RAG-Bot",
  "version": "1.0",
  "description": "Chat with YouTube videos using a RAG backend.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}